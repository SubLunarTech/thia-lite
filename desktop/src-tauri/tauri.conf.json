{
    "productName": "Thia-Lite",
    "version": "0.1.0",
    "identifier": "com.thia-libre.thia-lite",
    "build": {
        "beforeDevCommand": "",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "",
        "frontendDist": "../src"
    },
    "app": {
        "title": "Thia-Lite",
        "windows": [
            {
                "title": "Thia-Lite — AI Astrology Assistant",
