{
  "name": "thia-lite-desktop",
  "version": "0.3.31",
  "description": "Thia-Lite AI Astrology Assistant",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-rebuild -f -w node-llama-cpp || true",
    "prebuild": "node scripts/prebuild.js",
    "build": "npm run prebuild && electron-builder --linux AppImage --x64 --publish never",
    "build:win": "node scripts/build-win-bundle.js && electron-builder --win nsis --x64 --publish never",
    "build:mac": "npm run prebuild && electron-builder --mac dmg --publish never",
    "build:all": "npm run prebuild && electron-builder -wml --publish never",
    "smoke-test": "node scripts/smoke-test-asar.js"
  },
  "author": "Thia-Libre Contributors",
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-rebuild": "^3.2.7"
  },
  "build": {
    "productName": "Thia",
    "appId": "com.thia-libre.thia-lite",
    "directories": {
      "output": "dist"
    },
    "artifactName": "thia.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "llm-engine.js",
      "mcp-client.js",
      "src/**/*",
      "icons/**/*"
    ],
    "asarUnpack": [
      "node_modules/node-llama-cpp/**",
      "node_modules/@node-llama-cpp/**"
    ],
    "extraResources": [
      "bin/**/*",
      "resources/**/*"
    ],
    "win": {
      "target": "nsis",
      "executableName": "thia",
      "signAndEditExecutable": false,
      "icon": "icons/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "perMachine": false,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Thia-Lite",
      "artifactName": "thia-setup.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "icons/icon.png",
      "category": "public.app-category.medical"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icons/icon.png",
      "category": "Science"
    }
  },
  "dependencies": {
    "node-llama-cpp": "^3.0.0",
    "decompress": "^4.2.1",
    "electron-updater": "^6.0.0"
  }
}