{
  "name": "thia-lite-desktop",
  "version": "0.3.23",
  "description": "Thia-Lite AI Astrology Assistant",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux AppImage --x64 --publish never",
    "build:win": "electron-builder --win nsis --x64 --publish never",
    "build:mac": "electron-builder --mac dmg --publish never",
    "build:all": "electron-builder -wml --publish never",
    "smoke-test": "node scripts/smoke-test-asar.js"
  },
  "author": "Thia-Libre Contributors",
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "productName": "Thia",
    "appId": "com.thia-libre.thia-lite",
    "directories": {
      "output": "dist"
    },
    "artifactName": "thia.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "icons/**/*"
    ],
    "extraResources": [
      "bin/**/*"
    ],
    "win": {
      "target": "portable",
      "executableName": "thia",
      "signAndEditExecutable": false,
      "icon": "icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Thia-Lite"
    },
    "mac": {
      "target": "dmg",
      "icon": "icons/icon.png",
      "category": "public.app-category.medical"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icons/icon.png",
      "category": "Science"
    }
  },
  "dependencies": {
    "decompress": "^4.2.1",
    "call-bind-apply-helpers": "^1.0.2",
    "call-bind": "^1.0.8",
    "get-intrinsic": "^1.2.6"
  }
}